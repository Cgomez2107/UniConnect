# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google OAuth Configuration (obtained from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your_google_client_id_web.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your_google_client_id_ios.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your_google_client_id_android.apps.googleusercontent.com

# API Configuration
# Local network: Use IP address when running backend on local network (same WiFi)
EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:3000/api/v1

# Tunnel (alternative): For ngrok or Expo tunnel - requires active tunnel
# EXPO_PUBLIC_API_BASE_URL=https://your-ngrok-url.ngrok-free.dev/api/v1
