# Global
NODE_ENV=development
LOG_LEVEL=info

# Supabase as Postgres
SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=replace_me
SUPABASE_DB_SSL=true

# Shared auth transition (Supabase JWT validation)
SUPABASE_JWT_ISSUER=https://replace-project.supabase.co/auth/v1
SUPABASE_JWT_JWKS_URL=https://replace-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
