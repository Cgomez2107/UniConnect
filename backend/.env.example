# ============================================================================
# .env.example - Variables de entorno para backend UniConnect
# ============================================================================
# INSTRUCCIONES:
# 1. Copiar este archivo: cp .env.example .env
# 2. Editar .env con valores locales (NUNCA commitear secretos en .env)
# 3. .env siempre es local y gitignored
# 
# IMPORTANTE: Este archivo NO contiene secretos reales, solo ejemplos
# ============================================================================

# ══════════════════════════════════════════════════════════════════════════════
# SECCIÓN 1: ENTORNO (dev local vs producción)
# ══════════════════════════════════════════════════════════════════════════════
NODE_ENV=development
LOG_LEVEL=debug

# ══════════════════════════════════════════════════════════════════════════════
# SECCIÓN 2: BASE DE DATOS - Docker Compose (desarrollo local)
# ══════════════════════════════════════════════════════════════════════════════
# Usa estas variables cuando ejecutas: docker-compose up
# El docker-compose.yml usa estos valores como defaults

# Nombre de la base de datos a crear
DB_NAME=uniconnect_dev

# Usuario de PostgreSQL
DB_USER=postgres

# Contraseña de PostgreSQL (CAMBIAR en .env local)
DB_PASSWORD=postgres_password_dev

# Host y puerto (dentro de docker-compose, usar servicio 'db')
# No cambiar a menos que tengas setup especial
DATABASE_HOST=db
DATABASE_PORT=5432

# ══════════════════════════════════════════════════════════════════════════════
# SECCIÓN 3: JWT & Autenticación
# ══════════════════════════════════════════════════════════════════════════════
# Secretos para firmar JWT tokens
# CAMBIAR estos valores en .env local (no usar en producción)

JWT_ACCESS_SECRET=dev_secret_access_key_change_in_prod
JWT_REFRESH_SECRET=dev_secret_refresh_key_change_in_prod

# ══════════════════════════════════════════════════════════════════════════════
# SECCIÓN 4: SUPABASE (para conexión directa a Supabase - futuro)
# ══════════════════════════════════════════════════════════════════════════════
# Opcional: usar Supabase en lugar de PostgreSQL local
# DESCOMENTAR si usas Supabase en producción

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_JWT_SECRET=your-jwt-secret
# 
# SUPABASE_DB_HOST=db.your-project.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=your-db-password
# SUPABASE_DB_SSL=require
# 
# SUPABASE_JWT_ISSUER=https://your-project.supabase.co
# SUPABASE_JWT_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_AUDIENCE=authenticated

# ══════════════════════════════════════════════════════════════════════════════
# SECCIÓN 5: PUERTOS DE SERVICIOS (microservicios)
# ══════════════════════════════════════════════════════════════════════════════
# Gateway (punto de entrada)
GATEWAY_PORT=3000

# Servicios (si se ejecutan fuera de docker-compose)
AUTH_SERVICE_PORT=3100
STUDY_GROUPS_SERVICE_PORT=3101
RESOURCES_SERVICE_PORT=3103
MESSAGING_SERVICE_PORT=3104
PROFILES_CATALOG_SERVICE_PORT=3105
EVENTS_SERVICE_PORT=3106

# ══════════════════════════════════════════════════════════════════════════════
# NOTAS IMPORTANTES
# ══════════════════════════════════════════════════════════════════════════════
# - NO commitear .env (está en .gitignore)
# - Cambiar valores por defecto en tu máquina local
# - Para producción: usar variables de entorno del servidor/plataforma
# - Usar .env.example para documentar variables necesarias (sin secretos)

