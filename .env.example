# ============================================================================
# .env.example - Variables de entorno para levantar el stack completo
# Ubicacion: repo root
# ============================================================================

# Entorno
NODE_ENV=development
LOG_LEVEL=debug

# Base de datos (docker compose)
DB_NAME=uniconnect_dev
DB_USER=postgres
DB_PASSWORD=postgres_password_dev
DATABASE_HOST=db
DATABASE_PORT=5432

# JWT (backend)
JWT_ACCESS_SECRET=dev_secret_access_key_change_in_prod
JWT_REFRESH_SECRET=dev_secret_refresh_key_change_in_prod

# Frontend (Expo)
EXPO_PUBLIC_API_BASE_URL=http://backend:3000/api/v1
EXPO_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your_google_client_id_web.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your_google_client_id_ios.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your_google_client_id_android.apps.googleusercontent.com
